{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2023",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "maxNodeModuleJsDepth": 0,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": ["src/**/*.js", "tests/**/*.js", "scripts/**/*.mjs", "*.js"]
}
